<% if current_user %>
  <div class="flex flex-col h-screen">
    <!-- Header -->
    <header class="px-6 pt-4 pb-6 text-center">
      <h1 class="text-2xl font-bold text-white">Welcome back!</h1>
      <p class="text-sm text-white text-opacity-80">Your Life Balance Dashboard</p>
    </header>

    <!-- Total Score -->
    <div class="px-6 mb-8">
      <div class="bg-white bg-opacity-15 backdrop-blur-lg rounded-2xl p-6 border border-white border-opacity-20">
        <h2 class="text-center text-white text-opacity-90 text-sm font-medium mb-3">Your Total Score</h2>
        <div class="text-5xl font-bold text-center text-white"><%= @total_score %></div>
      </div>
    </div>

    <!-- Categories -->
    <div class="px-6 flex-1 overflow-y-auto pb-6">
      <h2 class="text-lg font-semibold text-white mb-4">Your Categories</h2>
      <div class="space-y-4">
        <% @categories.each do |category| %>
          <%= link_to category_path(category), class: "block group" do %>
            <div class="bg-white bg-opacity-10 backdrop-blur-lg rounded-2xl p-5 border border-white border-opacity-20 transition-all duration-200 group-hover:bg-opacity-20 group-active:scale-95">
              <div class="flex justify-between items-center">
                <div>
                  <h3 class="text-lg font-semibold text-white"><%= category.name %></h3>
                  <p class="text-sm text-white text-opacity-70"><%= category.description %></p>
                </div>
                <div class="text-3xl font-bold text-white"><%= category.score %></div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center h-full px-6 text-center">
    <div class="max-w-md">
      <h1 class="text-3xl font-bold text-white mb-4">Welcome to LifeBoard</h1>
      <p class="text-white text-opacity-80 mb-8">Track and improve different areas of your life with our simple, intuitive dashboard.</p>
      
      <div class="space-y-4">
        <%= link_to "Create an account", signup_path, class: "block w-full bg-white text-indigo-600 py-3 px-6 rounded-lg font-medium hover:bg-opacity-90 transition duration-200 text-center" %>
        <%= link_to "Log in", login_path, class: "block w-full bg-transparent border-2 border-white text-white py-3 px-6 rounded-lg font-medium hover:bg-white hover:bg-opacity-10 transition duration-200 text-center" %>
      </div>
      
      <div class="mt-8 p-6 bg-white bg-opacity-10 backdrop-blur-lg rounded-2xl border border-white border-opacity-20">
        <h3 class="text-lg font-semibold text-white mb-3">How it works</h3>
        <div class="space-y-4 text-left">
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 mt-1">
              <div class="w-6 h-6 rounded-full bg-indigo-500 flex items-center justify-center text-white text-sm font-bold">1</div>
            </div>
            <p class="text-white text-opacity-80 text-sm">Track your progress in Health, Personal, and Professional categories</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 mt-1">
              <div class="w-6 h-6 rounded-full bg-indigo-500 flex items-center justify-center text-white text-sm font-bold">2</div>
            </div>
            <p class="text-white text-opacity-80 text-sm">Set and track goals with our intuitive Trello-like interface</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 mt-1">
              <div class="w-6 h-6 rounded-full bg-indigo-500 flex items-center justify-center text-white text-sm font-bold">3</div>
            </div>
            <p class="text-white text-opacity-80 text-sm">Watch your total score improve as you make progress</p>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
