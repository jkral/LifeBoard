<div class="max-w-md mx-auto">
  <!-- App header -->
  <header class="text-center mb-8">
    <h1 class="text-2xl font-bold text-white">LifeBoard</h1>
    <p class="text-white/80 text-sm">Life Balance Dashboard</p>
  </header>
  
  <!-- Total score card -->
  <div class="bg-white/15 backdrop-blur-sm rounded-xl p-6 mb-8 border border-white/20 shadow-md">
    <div class="text-5xl font-bold text-white text-center">
      <%= number_with_precision(@total_score, precision: 1) %>
    </div>
  </div>
  
  <!-- Categories list -->
  <div class="space-y-4 mb-6">
    <% @categories.each do |category| %>
      <% score = category.score || 0 %>
      
      <%= link_to category_path(category), class: "block" do %>
        <div class="bg-white/15 backdrop-blur-sm rounded-xl p-4 border border-white/20">
          <div class="flex justify-between items-center">
            <div>
              <h3 class="text-white font-semibold"><%= category.name %></h3>
              <p class="text-white/70 text-sm"><%= category.description %></p>
            </div>
            <div class="text-2xl font-bold text-white">
              <%= number_with_precision(score, precision: 1) %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
    
    <!-- We've removed the 'Add Category' button since the route doesn't exist -->
  </div>
</div>
