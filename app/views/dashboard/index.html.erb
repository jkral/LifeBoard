<!-- Phone mockup container -->
<div class="bg-white rounded-[40px] shadow-2xl overflow-hidden border-[14px] border-gray-800 relative w-full max-w-[375px] mx-auto">
  <!-- Notch -->
  <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-3/4 h-6 bg-gray-800 rounded-b-2xl z-10"></div>
  
  <!-- Status bar -->
  <div class="absolute top-0 left-0 right-0 z-10 px-6 py-2 flex justify-between items-center">
    <span class="text-white text-sm font-medium"><%= Time.current.strftime('%H:%M') %></span>
    <div class="flex items-center space-x-2">
      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-1.414 1.414a5 5 0 01-7.072 0L9.05 12.12a3 3 0 000-4.242l1.171-1.172a5 5 0 017.071 0l1.414 1.414a1 1 0 010 1.414l-1.414 1.414a1 1 0 01-1.415 0l1.415-1.414-1.415-1.414a3 3 0 00-4.242 0l-1.172 1.171a1 1 0 000 1.414l1.414 1.414a3 3 0 004.242 0l1.414-1.414-1.414-1.414a1 1 0 010-1.414l1.414-1.414z" clip-rule="evenodd" />
      </svg>
      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M5 5a3 3 0 015.83-1.5h2.34A3 3 0 0116 5v.793a.5.5 0 01-.5.5h-11a.5.5 0 01-.5-.5V5z" clip-rule="evenodd" />
        <path d="M3 8.5a.5.5 0 01.5-.5h13a.5.5 0 01.5.5v6a2.5 2.5 0 01-2.5 2.5h-9A2.5 2.5 0 013 14.5v-6z" />
      </svg>
      <span class="text-white text-sm">100%</span>
    </div>
  </div>
  
  <!-- Screen content -->
  <div class="relative z-0 min-h-[700px] bg-gradient-to-br from-indigo-500 to-purple-600 p-6 pt-16">
    <!-- App header -->
    <header class="text-center mb-8">
      <h1 class="text-2xl font-bold text-white">LifeBoard</h1>
      <p class="text-white/80 text-sm">Life Balance Dashboard</p>
    </header>
    
    <% if current_user %>
      <!-- Total score card -->
      <div class="bg-white/15 backdrop-blur-lg rounded-2xl p-6 mb-6 border border-white/20 shadow-lg">
        <h2 class="text-white/80 text-center text-sm font-medium mb-2 tracking-wider">TOTAL SCORE</h2>
        <div class="text-5xl font-bold text-white text-center mb-2">
          <%= number_with_precision(@total_score, precision: 1) %>
          <span class="text-lg font-normal ml-1">/ 10</span>
        </div>
        <div class="h-2 bg-white/20 rounded-full overflow-hidden mt-4">
          <div class="h-full bg-white rounded-full" style="width: <%= [@total_score * 10, 100].min %>%"></div>
        </div>
      </div>
      
      <!-- Categories list -->
      <div class="space-y-4 mb-20">
        <h2 class="text-white font-medium text-sm tracking-wider mb-2">CATEGORIES</h2>
        
        <% @categories.each do |category| %>
          <% score = category.score || 0 %>
          <% percentage = (score / 10.0 * 100).round(0) %>
          
          <%= link_to category_path(category), class: "block group" do %>
            <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-5 border border-white/20 transition-all duration-200 group-hover:bg-white/20 group-active:scale-95">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="text-white font-semibold text-lg"><%= category.name %></h3>
                  <p class="text-white/70 text-sm mt-1"><%= category.description %></p>
                </div>
                <div class="relative w-12 h-12 bg-white/10 rounded-full flex items-center justify-center">
                  <span class="text-white font-bold"><%= number_with_precision(score, precision: 1) %></span>
                </div>
              </div>
              
              <div class="h-1.5 bg-white/20 rounded-full overflow-hidden">
                <div class="h-full bg-white rounded-full" style="width: <%= [percentage, 100].min %>%"></div>
              </div>
            </div>
          <% end %>
        <% end %>
        
        <!-- Add new category button -->
        <%= link_to new_category_path, class: "block mt-6" do %>
          <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-5 border-2 border-dashed border-white/30 flex items-center justify-center group hover:bg-white/20 transition-colors">
            <div class="text-white/70 group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mx-auto mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              <span class="text-sm font-medium">Add Category</span>
            </div>
          </div>
        <% end %>
      </div>
      
      <!-- Bottom navigation -->
      <div class="fixed bottom-0 left-0 right-0 bg-white/10 backdrop-blur-lg border-t border-white/20 p-3 flex justify-around">
        <button class="text-white p-2 rounded-xl bg-white/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </button>
        <button class="text-white p-2 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </button>
        <button class="text-white p-2 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </button>
      </div>
    <% else %>
      <!-- Not logged in state -->
      <div class="flex flex-col items-center justify-center h-[500px]">
        <div class="text-center px-4">
          <div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-white mb-3">Welcome to LifeBoard</h2>
          <p class="text-white/80 mb-8 text-sm">Track and improve your life balance with our intuitive dashboard.</p>
          <div class="space-y-3">
            <%= link_to "Sign In", login_path, class: "block w-full bg-white text-indigo-600 font-medium py-3 px-6 rounded-xl text-center hover:bg-opacity-90 transition-colors" %>
            <%= link_to "Create Account", signup_path, class: "block w-full bg-white/10 text-white font-medium py-3 px-6 rounded-xl text-center border border-white/20 hover:bg-white/20 transition-colors" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Real app navigation (hidden on mobile) -->
<div class="hidden md:flex justify-center mt-8 space-x-4">
  <% if current_user %>
    <%= link_to "Dashboard", dashboard_path, class: "px-4 py-2 bg-white/10 text-white rounded-lg hover:bg-white/20 transition-colors" %>
    <%= link_to "Profile", "#", class: "px-4 py-2 text-white/70 hover:text-white transition-colors" %>
    <%= button_to "Sign out", logout_path, method: :delete, class: "px-4 py-2 text-white/70 hover:text-white transition-colors" %>
  <% else %>
    <%= link_to "Sign In", login_path, class: "px-4 py-2 text-white/70 hover:text-white transition-colors" %>
    <%= link_to "Sign Up", signup_path, class: "px-4 py-2 bg-white/10 text-white rounded-lg hover:bg-white/20 transition-colors" %>
  <% end %>
</div>
