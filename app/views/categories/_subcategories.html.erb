<% subcategories.each do |subcategory| %>
  <div class="bg-white bg-opacity-10 rounded-xl p-4">
    <div class="flex justify-between items-center mb-2">
      <h3 class="text-white font-medium"><%= subcategory.name %></h3>
      <span class="text-xl font-bold text-white"><%= subcategory.score %></span>
    </div>
    <input 
      type="range" 
      min="1" 
      max="10" 
      step="0.1" 
      value="<%= subcategory.score %>" 
      class="w-full h-2 bg-white bg-opacity-20 rounded-lg appearance-none cursor-pointer"
      data-controller="score-slider"
      data-action="input->score-slider#updateScore"
      data-score-slider-subcategory-id-value="<%= subcategory.id %>"
    >
  </div>
<% end %>
