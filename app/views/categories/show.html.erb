<div class="max-w-md mx-auto">
  <!-- Category Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between mb-6">
      <%= link_to root_path, class: "p-2 rounded-full bg-white/15 hover:bg-white/25 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-bold text-white"><%= @category.name %></h1>
      <div class="w-9"></div> <!-- Spacer for flex alignment -->
    </div>
    
    <!-- Category Score -->
    <div class="bg-white/15 backdrop-blur-sm rounded-xl p-6 border border-white/20 mb-6">
      <h2 class="text-center text-white text-sm font-medium mb-3">Current Score</h2>
      <div class="text-5xl font-bold text-center text-white mb-4"><%= number_with_precision(@category.score, precision: 1) %></div>
      
      <!-- Subcategory Scores -->
      <div class="space-y-4">
        <% @subcategories.each do |subcategory| %>
          <div class="bg-white/10 rounded-xl p-4">
            <div class="flex justify-between items-center mb-2">
              <h3 class="text-white font-medium"><%= subcategory.name %></h3>
              <span class="text-xl font-bold text-white"><%= number_with_precision(subcategory.score, precision: 1) %></span>
            </div>
            <input 
              type="range" 
              min="1" 
              max="10" 
              step="0.1" 
              value="<%= subcategory.score %>" 
              class="w-full h-2 bg-white/20 rounded-lg appearance-none cursor-pointer"
              data-controller="score-slider"
              data-action="input->score-slider#updateScore"
              data-score-slider-subcategory-id-value="<%= subcategory.id %>"
            >
          </div>
        <% end %>
        
        <!-- Empty state message -->
        <% if @subcategories.empty? %>
          <div class="text-center text-white/70 py-3">
            <p class="mb-2">No subcategories yet</p>
          </div>
        <% end %>
        
        <!-- We've removed the 'Add Subcategory' button since the route doesn't exist -->
      </div>
    </div>
  </div>
  
  <!-- Goals Board -->
  <div class="mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-white">Goals</h2>
      <button class="bg-white/15 hover:bg-white/25 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        Add Goal
      </button>
    </div>
    
    <div class="overflow-x-auto pb-4">
      <div class="flex space-x-4 min-w-max">
        <!-- To Do Column -->
        <div class="w-64 bg-white/10 rounded-xl p-4 border border-white/20">
          <h3 class="text-white font-medium mb-4">To Do</h3>
          <div class="space-y-3">
            <!-- Sample Goal Card -->
            <div class="bg-white/10 rounded-lg p-3 border border-white/10">
              <h4 class="text-white font-medium text-sm">Morning Workout</h4>
              <p class="text-white/70 text-xs mt-1">30min exercise routine</p>
            </div>
          </div>
        </div>
        
        <!-- In Progress Column -->
        <div class="w-64 bg-white/10 rounded-xl p-4 border border-white/20">
          <h3 class="text-white font-medium mb-4">In Progress</h3>
          <div class="space-y-3">
            <!-- Sample Goal Card -->
            <div class="bg-white/10 rounded-lg p-3 border border-white/10">
              <h4 class="text-white font-medium text-sm">Sleep Schedule</h4>
              <p class="text-white/70 text-xs mt-1">8 hours consistent sleep</p>
            </div>
          </div>
        </div>
        
        <!-- Done Column -->
        <div class="w-64 bg-white/10 rounded-xl p-4 border border-white/20">
          <h3 class="text-white font-medium mb-4">Done</h3>
          <div class="space-y-3">
            <!-- Sample Goal Card -->
            <div class="bg-white/10 rounded-lg p-3 border border-white/10">
              <h4 class="text-white font-medium text-sm">Water Intake</h4>
              <p class="text-white/70 text-xs mt-1">Drink 8 glasses daily</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
