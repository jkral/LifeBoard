<div class="max-w-md mx-auto">
  <!-- Category Header -->
  <div class="category-header">
    <%= link_to root_path, class: "back-btn" do %>
      ← Back
    <% end %>
    <div class="category-title"><%= @category.name %></div>
    <div></div> <!-- Spacer for flex alignment -->
  </div>
  
  <!-- Category Score -->
  <div class="score-editor">
    <h3>Current <%= @category.name %> Score</h3>
    <div class="score-display"><%= number_with_precision(@category.score, precision: 1) %></div>
    
    <!-- Subcategory Scores -->
    <div class="subcategories">
      <% @subcategories.each do |subcategory| %>
        <div class="subcategory-item">
          <div class="subcategory-header">
            <h4><%= subcategory.name %></h4>
            <span><%= number_with_precision(subcategory.score, precision: 1) %></span>
          </div>
          <input 
            type="range" 
            class="score-slider"
            min="1" 
            max="10" 
            step="0.1" 
            value="<%= subcategory.score %>" 
            data-controller="score-slider"
            data-action="input->score-slider#updateScore"
            data-score-slider-subcategory-id-value="<%= subcategory.id %>"
          >
        </div>
      <% end %>
      
      <!-- Empty state message -->
      <% if @subcategories.empty? %>
        <div class="empty-state">
          <p>No subcategories yet</p>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Goals Board -->
  <div class="goals-section">
    <h3>
      Goals
      <button class="add-goal-btn">+ Add Goal</button>
    </h3>
    
    <div class="goals-board">
      <!-- To Do Column -->
      <div class="goal-column">
        <div class="column-title">To Do</div>
        <div class="goal-card">
          <div class="goal-title">Morning Workout</div>
          <div class="goal-desc">30min exercise routine</div>
        </div>
        <div class="goal-card">
          <div class="goal-title">Meal Prep</div>
          <div class="goal-desc">Prepare healthy meals</div>
        </div>
      </div>
      
      <!-- In Progress Column -->
      <div class="goal-column">
        <div class="column-title">In Progress</div>
        <div class="goal-card">
          <div class="goal-title">Sleep Schedule</div>
          <div class="goal-desc">8 hours consistent sleep</div>
        </div>
      </div>
      
      <!-- Done Column -->
      <div class="goal-column">
        <div class="column-title">Done</div>
        <div class="goal-card">
          <div class="goal-title">Water Intake</div>
          <div class="goal-desc">Drink 8 glasses daily</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Category Page Styles */
  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    color: white;
  }
  
  .back-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    padding: 8px 12px;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
  }
  
  .category-title {
    font-size: 20px;
    font-weight: bold;
  }
  
  .score-editor {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 25px;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.2);
  }
  
  .score-editor h3 {
    color: white;
    font-size: 14px;
    margin-bottom: 15px;
    opacity: 0.9;
  }
  
  .score-display {
    font-size: 42px;
    font-weight: bold;
    color: white;
    margin-bottom: 15px;
  }
  
  .subcategories {
    margin-top: 20px;
  }
  
  .subcategory-item {
    background: rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 15px;
    margin-bottom: 10px;
  }
  
  .subcategory-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  
  .subcategory-header h4 {
    color: white;
    font-weight: 500;
    font-size: 16px;
  }
  
  .subcategory-header span {
    color: white;
    font-weight: bold;
    font-size: 20px;
  }
  
  .empty-state {
    text-align: center;
    color: rgba(255,255,255,0.7);
    padding: 15px 0;
  }
  
  .goals-section h3 {
    color: white;
    font-size: 16px;
    margin-bottom: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .add-goal-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
  }
  
  .goals-board {
    display: flex;
    gap: 15px;
    overflow-x: auto;
    padding-bottom: 10px;
  }
  
  .goal-column {
    min-width: 160px;
    background: rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 12px;
  }
  
  .column-title {
    color: white;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
    text-align: center;
  }
  
  .goal-card {
    background: rgba(255,255,255,0.9);
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 8px;
    cursor: grab;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  
  .goal-card:active {
    cursor: grabbing;
  }
  
  .goal-title {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #1f2937;
  }
  
  .goal-desc {
    font-size: 11px;
    color: #6b7280;
    line-height: 1.3;
  }
</style>
