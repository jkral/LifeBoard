<div class="page-container">
  <!-- Category Header -->
  <div class="mb-4">
    <div class="category-header items-center">
      <%= link_to root_path, class: "back-btn mt-1" do %>
        ← Back
      <% end %>
      <div></div> <!-- Spacer for flex alignment -->
    </div>
    <h1 class="app-title text-center mt-4" style="font-size: 3rem; font-weight: bold; line-height: 1.2; color: white;"><%= @category.name %></h1>
  </div>
  
  <!-- Category Score -->
  <div class="score-editor">
    <h3>Current <%= @category.name %> Score</h3>
    <div class="score-display">
      <% if @category.score.to_f >= 9.95 %>
        10.0
      <% else %>
        <%= number_with_precision(@category.score, precision: 1) %>
      <% end %>
    </div>
    
    <!-- Subcategory Scores -->
    <div class="subcategories">
      <% @subcategories.each do |subcategory| %>
        <div class="subcategory-item">
          <div class="subcategory-header">
            <h4><%= subcategory.name %></h4>
            <span>
              <% if subcategory.score.to_f >= 9.95 %>
                10.0
              <% else %>
                <%= number_with_precision(subcategory.score, precision: 1) %>
              <% end %>
            </span>
          </div>
          <div class="slider-container">
            <input 
              type="range" 
              min="1.0" 
              max="10" 
              step="0.5" 
              value="<%= subcategory.score || 10.0 %>" 
              data-controller="score-slider"
              data-score-slider-subcategory-id-value="<%= subcategory.id %>"
              data-action="input->score-slider#updateScore"
              data-category-id="<%= @category.id %>" 
              data-subcategory-id="<%= subcategory.id %>" 
              class="score-slider"
              id="slider-<%= subcategory.id %>"
              aria-label="Score for <%= subcategory.name %>"
              aria-valuemin="1.0"
              aria-valuemax="10"
              aria-valuenow="<%= subcategory.score || 10.0 %>"
            >
            <div class="slider-ticks">
              <span>1</span>
              <span>5.5</span>
              <span>10</span>
            </div>
          </div>
        </div>
      <% end %>
      
      <!-- Empty state message -->
      <% if @subcategories.empty? %>
        <div class="empty-state">
          <p>No subcategories yet</p>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Goals Board -->
  <div class="goals-section" 
       data-controller="goals-board" 
       data-goals-board-category-id-value="<%= @category.id %>"
       data-action="turbo:before-cache@document->goals-board#cleanup turbo:before-render@document->goals-board#cleanup">
    <div class="goals-header">
      <h2>Goals</h2>
      <button id="add-goal-btn" class="add-goal-btn" type="button">+ Add Goal</button>
    </div>
    
    <div class="goals-board" data-goals-board-category-id-value="<%= @category.id %>">
      <!-- To Do Column -->
      <div class="goal-column" data-status="todo">
        <div class="column-header">
          <div class="column-title">To Do</div>
        </div>
        <div class="goals-container" data-goals-board-target="todoContainer">
          <!-- Goals will be loaded here by JavaScript -->
        </div>
      </div>
      
      <!-- In Progress Column -->
      <div class="goal-column" data-status="in_progress">
        <div class="column-header">
          <div class="column-title">In Progress</div>
        </div>
        <div class="goals-container" data-goals-board-target="inProgressContainer">
          <!-- Goals will be loaded here by JavaScript -->
        </div>
      </div>
      
      <!-- Done Column -->
      <div class="goal-column" data-status="done">
        <div class="column-header">
          <div class="column-title">Done</div>
        </div>
        <div class="goals-container" data-goals-board-target="doneContainer">
          <!-- Goals will be loaded here by JavaScript -->
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Goal Modal (now outside .page-container for proper overlay) -->
<div id="add-goal-modal" class="modal-overlay hidden">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">Add a Goal</h3>
      <button type="button" class="modal-close" id="close-add-goal-modal" aria-label="Close">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <%= render 'goals/form', goal: Goal.new, category: @category %>
    </div>
  </div>
</div>

<script>
  // This will be managed by the Stimulus controller
  document.addEventListener('turbo:load', function() {
    // This ensures compatibility with both full page loads and Turbo visits
    if (window.goalsBoardController) {
      window.goalsBoardController.initialize();
    }
  });
  
  // Clean up on Turbo cache
  document.addEventListener('turbo:before-cache', function() {
    if (window.goalsBoardController) {
      window.goalsBoardController.cleanup();
    }
  });
  
  // Function to escape HTML to prevent XSS
  function escapeHtml(unsafe) {
    if (!unsafe) return ''
    return unsafe
      .toString()
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;")
  }
  
  // Function to create a goal element
  function createGoalElement(goal) {
    const element = document.createElement('div')
    element.className = 'goal-card'
    element.dataset.goalId = goal.id
    element.draggable = true
    
    // Add drag event handlers
    element.addEventListener('dragstart', handleDragStart)
    element.addEventListener('dragend', handleDragEnd)
    
    element.innerHTML = `
      <div class="goal-title">${escapeHtml(goal.title)}</div>
      ${goal.description ? `<div class="goal-desc">${escapeHtml(goal.description)}</div>` : ''}
      <div class="goal-actions">
        <button class="edit-goal" data-goal-id="${goal.id}">✏️</button>
        <button class="delete-goal" data-goal-id="${goal.id}">🗑️</button>
      </div>
    `
    
    // Add event listeners for edit and delete buttons
    const editBtn = element.querySelector('.edit-goal')
    const deleteBtn = element.querySelector('.delete-goal')
    
    if (editBtn) {
      editBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        editGoal(goal.id, e)
      })
    }
    
    if (deleteBtn) {
      deleteBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        deleteGoal(goal.id, e)
      })
    }
    
    return element
  }
  
  // Drag start handler
  function handleDragStart(e) {
    draggedItem = this
    this.classList.add('dragging')
    e.dataTransfer.effectAllowed = 'move'
    e.dataTransfer.setData('text/plain', this.dataset.goalId)
    
    // Add a small delay to allow the drag image to be set
    setTimeout(() => this.classList.add('hide-while-dragging'), 0)
  }
  
  // Drag end handler
  function handleDragEnd() {
    this.classList.remove('dragging', 'hide-while-dragging')
    document.querySelectorAll('.goal-column').forEach(col => {
      col.classList.remove('drag-over')
    })
    // Clean up any remaining insertion lines
    document.querySelectorAll('.goal-insertion-line').forEach(el => el.remove())
  }
  
  // Setup drag and drop for all columns
  function setupDragAndDrop() {
    const columns = document.querySelectorAll('.goal-column')
    
    columns.forEach(column => {
      const container = column.querySelector('.goals-container')
      if (!container) return
      
      // Make the entire column a drop target
      column.addEventListener('dragover', function(e) {
        e.preventDefault()
        e.dataTransfer.dropEffect = 'move'
        this.classList.add('drag-over')
      })
      
      column.addEventListener('dragleave', function(e) {
        // Only remove drag-over if we're leaving the column, not just moving between children
        if (!this.contains(e.relatedTarget)) {
          this.classList.remove('drag-over')
        }
      })
      
      column.addEventListener('drop', async function(e) {
        e.preventDefault()
        e.stopPropagation()
        this.classList.remove('drag-over')
        
        if (!draggedItem) return
        
        const goalId = draggedItem.dataset.goalId
        const newStatus = this.dataset.status
        const container = this.querySelector('.goals-container')
        
        if (!container) return
        
        // Get the position to insert the dragged item
        const afterElement = getDragAfterElement(container, e.clientY)
        
        // Update the DOM
        if (afterElement && afterElement.element) {
          container.insertBefore(draggedItem, afterElement.element)
        } else {
          container.appendChild(draggedItem)
        }
        
        // Update the goal's status and position on the server
        try {
          await updateGoalStatus(goalId, newStatus)
          await updateGoalPosition(goalId, newStatus)
        } catch (error) {
          console.error('Error updating goal:', error)
          // Revert the UI if there's an error
          window.location.reload()
        }
      })
      
      // Handle drag over for reordering within the same container
      container.addEventListener('dragover', function(e) {
        e.preventDefault()
        e.dataTransfer.dropEffect = 'move'
        
        // Remove any existing insertion lines
        document.querySelectorAll('.goal-insertion-line').forEach(el => el.remove())
        
        const { element: afterElement, insertAtTop } = getDragAfterElement(this, e.clientY)
        const draggable = document.querySelector('.dragging')
        
        // Insert the draggable element
        if (afterElement) {
          if (insertAtTop) {
            this.insertBefore(draggable, afterElement)
            // Add insertion line before the first element
            const line = document.createElement('div')
            line.className = 'goal-insertion-line visible'
            line.style.top = (afterElement.offsetTop - 1) + 'px'
            this.insertBefore(line, afterElement)
          } else {
            this.insertBefore(draggable, afterElement.nextSibling)
            // Add insertion line after the element
            const line = document.createElement('div')
            line.className = 'goal-insertion-line visible'
            const rect = afterElement.getBoundingClientRect()
            line.style.top = (rect.bottom - this.getBoundingClientRect().top - 1) + 'px'
            this.appendChild(line)
          }
        } else {
          this.appendChild(draggable)
        }
      })
      
      // Clean up insertion lines when leaving the container
      container.addEventListener('dragleave', function() {
        document.querySelectorAll('.goal-insertion-line').forEach(el => el.remove())
      })
    })
  }
  
  // Helper to find the element after which to insert the dragged item
  function getDragAfterElement(container, y) {
    const draggableElements = [...container.querySelectorAll('.goal-card:not(.dragging)')]
    let closest = { offset: Number.NEGATIVE_INFINITY, element: null }
    let insertionY = 0
    
    // If container is empty, return null to append at the end
    if (draggableElements.length === 0) {
      return { element: null, insertAtTop: true }
    }
    
    // Check if we're at the top of the container
    const firstElement = draggableElements[0]
    const firstBox = firstElement.getBoundingClientRect()
    if (y < firstBox.top + firstBox.height * 0.25) {
      return { element: firstElement, insertAtTop: true }
    }
    
    // Check each element to find the closest one
    for (let i = 0; i < draggableElements.length; i++) {
      const box = draggableElements[i].getBoundingClientRect()
      const offset = y - box.top - box.height / 2
      
      if (offset < 0 && offset > closest.offset) {
        closest = { offset, element: draggableElements[i] }
      }
    }
    
    return { element: closest.element, insertAtTop: false }
  }
  
  // Update goal position on the server
  async function updateGoalPosition(goalId, newStatus) {
    const categoryId = document.querySelector('[data-goals-board-category-id-value]').dataset.goalsBoardCategoryIdValue
    const goalElements = document.querySelectorAll(`[data-status="${newStatus}"] .goal-card`)
    const position = Array.from(goalElements).findIndex(el => el.dataset.goalId === goalId)
    
    try {
      const response = await fetch(`/categories/${categoryId}/goals/${goalId}.json`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector("meta[name='csrf-token']").content
        },
        body: JSON.stringify({
          goal: {
            status: newStatus,
            position: position
          }
        })
      })
      
      if (!response.ok) {
        throw new Error('Failed to update goal position')
      }
      
      console.log('Goal position updated')
      
    } catch (error) {
      console.error('Error updating goal position:', error)
      // Revert the UI if the server update fails
      window.location.reload()
    }
  }
  
  // Helper function to escape HTML
  function escapeHtml(unsafe) {
    return unsafe
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;")
  }
  
  // Function to edit a goal
  window.editGoal = async function(goalId) {
    const goalElement = document.querySelector(`[data-goal-id="${goalId}"]`)
    if (!goalElement) return

    // Get current values
    const title = goalElement.querySelector('.goal-title').textContent
    const descElement = goalElement.querySelector('.goal-desc')
    const currentDesc = descElement ? descElement.textContent : ''

    // Open the modal
    const addGoalModal = document.getElementById('add-goal-modal')
    addGoalModal.classList.remove('hidden')

    // Fill the form fields
    const titleInput = addGoalModal.querySelector('input[name="goal[title]"]')
    const descInput = addGoalModal.querySelector('textarea[name="goal[description]"]')
    const statusInput = addGoalModal.querySelector('[name="goal[status]"]')
    if (titleInput) titleInput.value = title
    if (descInput) descInput.value = currentDesc
    if (statusInput) {
      // Try to get the status from the goal element's data-status or a class/attribute
      let currentStatus = goalElement.closest('.goal-column')?.dataset.status
      if (!currentStatus) {
        // fallback: try to get from a data-status attribute on the card
        currentStatus = goalElement.dataset.status
      }
      if (currentStatus) statusInput.value = currentStatus
    }

    // Set form action/method for PATCH
    const form = addGoalModal.querySelector('form')
    const categoryId = document.querySelector('[data-goals-board-category-id-value]')?.dataset?.goalsBoardCategoryIdValue
    form.action = `/categories/${categoryId}/goals/${goalId}`
    form.method = 'post'
    // Add hidden _method input for PATCH
    let methodInput = form.querySelector('input[name="_method"]')
    if (!methodInput) {
      methodInput = document.createElement('input')
      methodInput.type = 'hidden'
      methodInput.name = '_method'
      form.appendChild(methodInput)
    }
    methodInput.value = 'patch'

    // Ensure authenticity_token is present and correct
    let tokenInput = form.querySelector('input[name="authenticity_token"]')
    const pageToken = document.querySelector('meta[name="csrf-token"]')?.content
    if (!tokenInput && pageToken) {
      tokenInput = document.createElement('input')
      tokenInput.type = 'hidden'
      tokenInput.name = 'authenticity_token'
      tokenInput.value = pageToken
      form.appendChild(tokenInput)
    } else if (tokenInput && pageToken) {
      tokenInput.value = pageToken
    }

    // Change submit button text to 'Update Goal'
    const submitBtn = form.querySelector('input[type="submit"]')
    if (submitBtn) submitBtn.value = 'Update Goal'

    // Mark modal as edit mode
    addGoalModal.setAttribute('data-editing', 'true')
  }
  
  // Function to delete a goal
  async function deleteGoal(goalId) {
    if (!confirm('Are you sure you want to delete this goal?')) return
    
    const categoryId = document.querySelector('[data-goals-board-category-id-value]').dataset.goalsBoardCategoryIdValue
    
    try {
      const response = await fetch(`/categories/${categoryId}/goals/${goalId}.json`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-Token': document.querySelector("meta[name='csrf-token']").content
        }
      })
      
      if (!response.ok) throw new Error('Failed to delete goal')
      
      // Remove from UI
      const goalElement = document.querySelector(`[data-goal-id="${goalId}"]`)
      if (goalElement) goalElement.remove()
      
    } catch (error) {
      console.error('Error deleting goal:', error)
      alert('Failed to delete goal. Please check the console for details.')
    }
  }
  
  // Function to update a goal's status on the server
  async function updateGoalStatus(goalId, newStatus) {
    try {
      const categoryId = document.querySelector('[data-goals-board-category-id-value]')?.dataset?.goalsBoardCategoryIdValue
      if (!categoryId) {
        throw new Error('Category ID not found')
      }
      
      const csrfToken = document.querySelector("meta[name='csrf-token']")?.content
      if (!csrfToken) {
        throw new Error('CSRF token not found')
      }
      
      const response = await fetch(`/categories/${categoryId}/goals/${goalId}.json`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
          goal: {
            status: newStatus
          }
        }),
        credentials: 'same-origin'
      })
      
      if (!response.ok) {
        const error = await response.text()
        throw new Error(error || 'Failed to update goal status')
      }
      
      return await response.json()
    } catch (error) {
      console.error('Error updating goal status:', error)
      throw error
    }
  }
  
  // Function to update a goal's position on the server
  async function updateGoalPosition(goalId, status, position = 0) {
    try {
      const categoryId = document.querySelector('[data-goals-board-category-id-value]')?.dataset?.goalsBoardCategoryIdValue
      if (!categoryId) {
        throw new Error('Category ID not found')
      }
      
      const csrfToken = document.querySelector("meta[name='csrf-token']")?.content
      if (!csrfToken) {
        throw new Error('CSRF token not found')
      }
      
      const response = await fetch(`/categories/${categoryId}/goals/${goalId}/move.json`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
          position: position,
          status: status
        }),
        credentials: 'same-origin'
      })
      
      if (!response.ok) {
        const error = await response.text()
        throw new Error(error || 'Failed to update goal position')
      }
      
      return await response.json()
    } catch (error) {
      console.error('Error updating goal position:', error)
      throw error
    }
  }
  
  // Function to load goals
  async function loadGoals() {
    try {
      console.log('Loading goals...')
      const categoryId = document.querySelector('[data-goals-board-category-id-value]')?.dataset.goalsBoardCategoryIdValue
      console.log('Category ID:', categoryId)
      
      if (!categoryId) {
        console.error('No category ID found')
        return
      }
      
      const response = await fetch(`/categories/${categoryId}/goals.json`, {
        credentials: 'same-origin',
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      if (!response.ok) throw new Error('Failed to load goals')
      
      const goals = await response.json()
      console.log('Goals loaded:', goals)
      
      // Clear existing goals
      document.querySelectorAll('.goals-container').forEach(container => {
        container.innerHTML = ''
      })
      
      // Add goals to their respective columns
      Object.entries(goals).forEach(([status, statusGoals]) => {
        console.log('Processing status:', status, 'with', statusGoals?.length, 'goals')
        const container = document.querySelector(`[data-status="${status}"] .goals-container`)
        console.log('Container for status', status, ':', container)
        
        if (container && Array.isArray(statusGoals)) {
          statusGoals.forEach(goal => {
            container.appendChild(createGoalElement(goal))
          })
        }
      })
      
      // Initialize drag and drop
      setupDragAndDrop()
      
    } catch (error) {
      console.error('Error loading goals:', error)
    }
  }
  
  // Initialize goals board
  function initializeGoalsBoard() {
    // Store a reference to the controller for cleanup
    window.goalsBoardController = {
      initialize: function() {
        console.log('Initializing goals board...')
        this.cleanup(); // Clean up any existing listeners
        this.setupEventListeners();
        loadGoals();
      },
      
      setupEventListeners: function() {
        // Add event listener for the Add Goal button
        this.addGoalBtn = document.getElementById('add-goal-btn')
        if (this.addGoalBtn) {
          // No longer attach the old handleAddGoal; modal logic is handled separately
        }
      },
      
      cleanup: function() {
        console.log('Cleaning up goals board...')
        // Remove event listeners
        if (this.addGoalBtn) {
          // Remove event listeners for the Add Goal button
          this.addGoalBtn.removeEventListener('click');
        }
        // Clean up drag and drop
        const columns = document.querySelectorAll('.goal-column');
        columns.forEach(column => {
          column.replaceWith(column.cloneNode(true));
        });
      }
    };
    
    // Initialize on page load
    window.goalsBoardController.initialize();
  }
  
  // Initialize when the DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeGoalsBoard);
  } else {
    initializeGoalsBoard();
  }

  // Modal open/close logic for Add Goal
  document.addEventListener('DOMContentLoaded', function() {
    console.log('[Add Goal Modal] Modal JS loaded');
    const addGoalBtn = document.getElementById('add-goal-btn');
    const addGoalModal = document.getElementById('add-goal-modal');
    const closeModalBtn = document.getElementById('close-add-goal-modal');
    const cancelBtn = document.querySelector('#add-goal-modal .goal-form-button-row button[type="button"]');
    if (addGoalBtn && addGoalModal) {
      addGoalBtn.addEventListener('click', function() {
        console.log('[Add Goal Modal] Add Goal button clicked');
        addGoalModal.classList.remove('hidden');
      });
      addGoalModal.addEventListener('click', function(e) {
        if (e.target === addGoalModal) {
          addGoalModal.classList.add('hidden');
        }
      });
    }
    if (closeModalBtn && addGoalModal) {
      closeModalBtn.addEventListener('click', function() {
        addGoalModal.classList.add('hidden');
        clearGoalForm();
      });
    }
    if (cancelBtn && addGoalModal) {
      cancelBtn.addEventListener('click', function() {
        addGoalModal.classList.add('hidden');
        clearGoalForm();
      });
    }
  });

  function clearGoalForm() {
    const modal = document.getElementById('add-goal-modal');
    if (!modal) return;
    const titleInput = modal.querySelector('input[name="goal[title]"]');
    const descInput = modal.querySelector('textarea[name="goal[description]"]');
    if (titleInput) titleInput.value = '';
    if (descInput) descInput.value = '';
    // Reset form action/method to Add
    const form = modal.querySelector('form')
    const categoryId = document.querySelector('[data-goals-board-category-id-value]')?.dataset?.goalsBoardCategoryIdValue
    form.action = `/categories/${categoryId}/goals`
    form.method = 'post'
    // Remove only _method input if present, but never remove authenticity_token
    const methodInput = form.querySelector('input[name="_method"]')
    if (methodInput) methodInput.remove()
    // Reset submit button text
    const submitBtn = form.querySelector('input[type="submit"]')
    if (submitBtn) submitBtn.value = 'Add Goal'
    // Remove edit mode marker
    modal.removeAttribute('data-editing')
    // Double-check authenticity_token is present
    let tokenInput = form.querySelector('input[name="authenticity_token"]')
    if (!tokenInput) {
      // Try to find it elsewhere in the DOM and append if missing
      const pageToken = document.querySelector('meta[name="csrf-token"]')?.content
      if (pageToken) {
        tokenInput = document.createElement('input')
        tokenInput.type = 'hidden'
        tokenInput.name = 'authenticity_token'
        tokenInput.value = pageToken
        form.appendChild(tokenInput)
      }
    }
  }

  // Intercept modal form submission for add/edit goal
  document.addEventListener('DOMContentLoaded', function() {
    const addGoalModal = document.getElementById('add-goal-modal');
    if (!addGoalModal) return;
    const form = addGoalModal.querySelector('form');
    if (!form) return;
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(form);
      const action = form.action;
      const method = form.querySelector('input[name="_method"]')?.value?.toUpperCase() || form.method.toUpperCase();
      try {
        const response = await fetch(action, {
          method: method === 'PATCH' ? 'PATCH' : 'POST',
          headers: {
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: formData,
          credentials: 'same-origin'
        });
        if (!response.ok) {
          const error = await response.text();
          alert('Failed to save goal: ' + error);
          return;
        }
        // Success: close modal, clear form, reload goals
        addGoalModal.classList.add('hidden');
        clearGoalForm();
        if (window.loadGoals) window.loadGoals();
      } catch (error) {
        alert('Failed to save goal: ' + error);
      }
    });
  });
</script>

