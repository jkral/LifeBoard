<script>
  // Debounce function to limit how often a function can be called
  function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
      const later = () => {
        clearTimeout(timeout);
        func.apply(this, args);
      };
      clearTimeout(timeout);
      timeout = setTimeout(later, wait);
    };
  }

  // Helper function to update the subcategory score display
  function updateSubcategoryScoreDisplay(slider, score = null) {
    // If score is not provided, get it from the slider
    if (score === null) {
      score = parseFloat(slider.value);
    }
    
    const parentItem = slider.closest('.subcategory-item');
    if (parentItem) {
      const scoreDisplay = parentItem.querySelector('.subcategory-header span');
      if (scoreDisplay) {
        // Force exact 10.0 value if the score is very close to 10
        if (score >= 9.95) {
          scoreDisplay.textContent = '10.0';
        } else {
          scoreDisplay.textContent = score.toFixed(1);
        }
      }
    }
  }
  
  // Helper function to update the category score display
  function updateCategoryScoreDisplay(score) {
    const categoryScoreDisplay = document.querySelector('.score-display');
    if (categoryScoreDisplay) {
      if (score >= 9.95) {
        categoryScoreDisplay.textContent = '10.0';
      } else {
        categoryScoreDisplay.textContent = score.toFixed(1);
      }
    }
  }
  
  // Calculate and update the category score based on all active sliders
  function updateCategoryScore() {
    const sliders = document.querySelectorAll('.score-slider');
    if (sliders.length === 0) return 0;
    
    // Calculate the average score
    let total = 0;
    sliders.forEach(slider => {
      total += parseFloat(slider.value);
    });
    
    let avgScore = total / sliders.length;
    
    // Check if all sliders are at max value
    const allAtMax = Array.from(sliders).every(slider => parseFloat(slider.value) >= 9.95);
    
    // Calculate the final score
    const finalScore = allAtMax ? 10.0 : parseFloat(avgScore.toFixed(1));
    
    // Update the category score display
    updateCategoryScoreDisplay(finalScore);
    
    return finalScore;
  }
  
  // Update the subcategory score display when slider moves
  function updateSubcategoryScore(slider) {
    try {
      // Get the values from the slider
      const score = parseFloat(slider.value);
      const subcategoryId = slider.dataset.subcategoryId;
      const categoryId = slider.dataset.categoryId;
      
      if (!subcategoryId || !categoryId) {
        throw new Error('Missing required data attributes on slider');
      }
      
      console.group('Updating Score');
      console.log('Score:', score);
      console.log('Subcategory ID:', subcategoryId);
      console.log('Category ID:', categoryId);
      
      // Update the displayed score in the UI immediately for better UX
      updateSubcategoryScoreDisplay(slider);
      
      // Update the category score immediately (client-side)
      updateCategoryScore();
      
      // Get CSRF token
      const token = document.querySelector('meta[name="csrf-token"]')?.content;
      if (!token) {
        throw new Error('CSRF token not found');
      }
      
      const url = `/categories/${categoryId}/subcategories/${subcategoryId}`;
      const requestBody = { 
        subcategory: { 
          score: score
        } 
      };
      
      console.log('Sending request to:', url);
      console.log('Request body:', requestBody);
      
      // Send AJAX request to update the database using the correct nested route
      fetch(url, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': token,
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'  // Helps identify AJAX requests
        },
        body: JSON.stringify(requestBody),
        credentials: 'same-origin'  // Include cookies for authentication
      })
      .then(async response => {
        console.log('Response status:', response.status);
        const responseText = await response.text();
        console.log('Response text:', responseText);
        
        if (!response.ok) {
          throw new Error(`Server responded with ${response.status}: ${responseText}`);
        }
        
        // Try to parse JSON, but handle the case where it might be empty
        try {
          return responseText ? JSON.parse(responseText) : {};
        } catch (e) {
          console.warn('Failed to parse JSON response:', e);
          return {};
        }
      })
      .then(data => {
        console.log('Parsed response data:', data);
        
        // Update the UI with the server's version of the scores
        if (data.subcategory_score !== undefined) {
          updateSubcategoryScoreDisplay(slider, data.subcategory_score);
          // Update slider value to match server response
          slider.value = data.subcategory_score;
        }
        
        if (data.category_score !== undefined) {
          updateCategoryScoreDisplay(data.category_score);
        }
        
        console.log('Score update successful');
      })
      .catch(error => {
        console.error('Error updating score:', error);
        
        // Revert the UI to show the error state
        updateSubcategoryScoreDisplay(slider);
        
        // Show error to user
        const errorDisplay = document.createElement('div');
        errorDisplay.className = 'error-message';
        errorDisplay.textContent = `Failed to update score: ${error.message || 'Unknown error'}`.substring(0, 100);
        errorDisplay.style.color = 'red';
        errorDisplay.style.marginTop = '5px';
        errorDisplay.style.fontSize = '0.8em';
        errorDisplay.style.whiteSpace = 'nowrap';
        errorDisplay.style.overflow = 'hidden';
        errorDisplay.style.textOverflow = 'ellipsis';
        
        // Remove any existing error messages
        const existingError = slider.parentNode.querySelector('.error-message');
        if (existingError) {
          existingError.remove();
        }
        
        // Add the new error message
        slider.parentNode.appendChild(errorDisplay);
        
        // Remove the error after 5 seconds
        setTimeout(() => {
          if (errorDisplay.parentNode) {
            errorDisplay.remove();
          }
        }, 5000);
      })
      .finally(() => {
        console.groupEnd();
      });
      
    } catch (error) {
      console.error('Error in updateSubcategoryScore:', error);
      console.groupEnd();
    }
  }
  
  // Create a debounced version of the update function
  const debouncedUpdateSubcategoryScore = debounce(function(slider) {
    console.log('debouncedUpdateSubcategoryScore called with slider:', slider);
    try {
      if (!slider || !slider.dataset || !slider.dataset.subcategoryId) {
        throw new Error('Invalid slider element');
      }
      updateSubcategoryScore(slider);
    } catch (error) {
      console.error('Error in debounced update:', error);
    }
  }, 300);
  
  // Function to handle slider input with debouncing
  function handleSliderInput(event) {
    try {
      const slider = event.target;
      
      // Log the input event for debugging
      console.group('Slider Input Event');
      console.log('Slider:', slider);
      console.log('Value:', slider.value);
      console.log('Dataset:', JSON.parse(JSON.stringify(slider.dataset)));
      console.groupEnd();
      
      // Validate the slider value
      const value = parseFloat(slider.value);
      if (isNaN(value) || value < 1 || value > 10) {
        console.warn('Invalid slider value:', value);
        return;
      }
      
      // Immediately update the display for better UX
      updateSubcategoryScoreDisplay(slider);
      
      // Update the category score immediately (client-side only)
      updateCategoryScore();
      
      // Call the debounced update function
      console.log('Calling debounced update...');
      debouncedUpdateSubcategoryScore.flush();
      
      // Add a visual indicator that the update is in progress
      const parentItem = slider.closest('.subcategory-item');
      if (parentItem) {
        parentItem.classList.add('updating');
        
        // Remove the class after a delay if the update takes too long
        setTimeout(() => {
          parentItem.classList.remove('updating');
        }, 2000);
      }
      
    } catch (error) {
      console.error('Error in handleSliderInput:', error);
    }
  }
  
  // Function to initialize a single slider
  function initializeSlider(slider) {
    console.log('Initializing slider:', slider);
    
    // Set default value if needed
    if (!slider.value || slider.value < 1) {
      slider.value = 10.0;
      updateSubcategoryScoreDisplay(slider);
    }
    
    // Remove any existing listeners
    const newSlider = slider.cloneNode(true);
    slider.parentNode.replaceChild(newSlider, slider);
    
    // Add input event listener to the new slider
    newSlider.addEventListener('input', function(e) {
      console.log('Slider input event triggered:', e);
      handleSliderInput(e);
    });
    
    // Add change event listener for when slider is released
    newSlider.addEventListener('change', function(e) {
      console.log('Slider change event triggered:', e);
      // Force immediate update on change
      debouncedUpdateSubcategoryScore.flush();
    });
    
    // Mark as initialized
    newSlider.setAttribute('data-initialized', 'true');
    
    console.log('Slider initialized with value:', newSlider.value);
    return newSlider;
  }
  
  // Initialize all sliders on the page
  function initializeAllSliders() {
    console.log('Initializing all sliders...');
    const sliders = document.querySelectorAll('.score-slider:not([data-initialized="true"])');
    console.log(`Found ${sliders.length} uninitialized sliders`);
    
    sliders.forEach((slider, index) => {
      console.log(`Initializing slider ${index + 1}:`, slider);
      initializeSlider(slider);
    });
    
    // Calculate initial category score
    updateCategoryScore();
    console.log('Slider initialization complete');
  }
  
  // Initialize sliders when the DOM is fully loaded
  document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM fully loaded, initializing sliders...');
    initializeAllSliders();
    
    // Re-initialize sliders after Turbo navigation
    document.addEventListener('turbo:load', function() {
      console.log('Turbo navigation detected, reinitializing sliders...');
      initializeAllSliders();
    });
  });
  
  // Also try to initialize sliders immediately in case DOM is already loaded
  if (document.readyState === 'loading') {
    // Loading hasn't finished yet, wait for DOMContentLoaded
    document.addEventListener('DOMContentLoaded', initializeAllSliders);
  } else {
    // DOM is already ready, initialize immediately
    setTimeout(initializeAllSliders, 100);
  }
</script>
