<div class="flex flex-col h-screen">
  <!-- Category Header -->
  <div class="px-6 pt-4 pb-6">
    <div class="flex items-center justify-between mb-6">
      <%= link_to root_path, class: "p-2 rounded-full bg-white bg-opacity-10 hover:bg-opacity-20 transition-colors duration-200" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-bold text-white"><%= @category.name %></h1>
      <div class="w-9"></div> <!-- Spacer for flex alignment -->
    </div>
    
    <!-- Category Score -->
    <div class="bg-white bg-opacity-15 backdrop-blur-lg rounded-2xl p-6 border border-white border-opacity-20 mb-6">
      <h2 class="text-center text-white text-opacity-90 text-sm font-medium mb-3">Current Score</h2>
      <div class="text-5xl font-bold text-center text-white mb-4"><%= @category.score %></div>
      
      <!-- Subcategory Scores -->
      <div class="space-y-4">
        <% @subcategories.each do |subcategory| %>
          <div class="bg-white bg-opacity-10 rounded-xl p-4">
            <div class="flex justify-between items-center mb-2">
              <h3 class="text-white font-medium"><%= subcategory.name %></h3>
              <span class="text-xl font-bold text-white"><%= subcategory.score %></span>
            </div>
            <input 
              type="range" 
              min="1" 
              max="10" 
              step="0.1" 
              value="<%= subcategory.score %>" 
              class="w-full h-2 bg-white bg-opacity-20 rounded-lg appearance-none cursor-pointer"
              data-controller="score-slider"
              data-action="input->score-slider#updateScore"
              data-score-slider-subcategory-id-value="<%= subcategory.id %>"
            >
          </div>
        <% end %>
      </div>
    </div>
  </div>
  
  <!-- Goals Board -->
  <div class="px-6 flex-1 overflow-hidden flex flex-col">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-white">Goals</h2>
      <button class="bg-white bg-opacity-10 hover:bg-opacity-20 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200">
        + Add Goal
      </button>
    </div>
    
    <div class="flex-1 overflow-hidden">
      <div class="flex h-full space-x-4 overflow-x-auto pb-4">
        <!-- To Do Column -->
        <div class="flex-shrink-0 w-64 bg-white bg-opacity-5 rounded-xl p-4 border border-white border-opacity-10 overflow-y-auto">
          <h3 class="text-white font-medium mb-4">To Do</h3>
          <div class="space-y-3">
            <!-- Sample Goal Card -->
            <div class="bg-white bg-opacity-10 rounded-lg p-3 border border-white border-opacity-10">
              <h4 class="text-white font-medium text-sm">Morning Workout</h4>
              <p class="text-white text-opacity-70 text-xs mt-1">30min exercise routine</p>
            </div>
          </div>
        </div>
        
        <!-- In Progress Column -->
        <div class="flex-shrink-0 w-64 bg-white bg-opacity-5 rounded-xl p-4 border border-white border-opacity-10 overflow-y-auto">
          <h3 class="text-white font-medium mb-4">In Progress</h3>
          <div class="space-y-3">
            <!-- Sample Goal Card -->
            <div class="bg-white bg-opacity-10 rounded-lg p-3 border border-white border-opacity-10">
              <h4 class="text-white font-medium text-sm">Sleep Schedule</h4>
              <p class="text-white text-opacity-70 text-xs mt-1">8 hours consistent sleep</p>
            </div>
          </div>
        </div>
        
        <!-- Done Column -->
        <div class="flex-shrink-0 w-64 bg-white bg-opacity-5 rounded-xl p-4 border border-white border-opacity-10 overflow-y-auto">
          <h3 class="text-white font-medium mb-4">Done</h3>
          <div class="space-y-3">
            <!-- Sample Goal Card -->
            <div class="bg-white bg-opacity-10 rounded-lg p-3 border border-white border-opacity-10">
              <h4 class="text-white font-medium text-sm">Water Intake</h4>
              <p class="text-white text-opacity-70 text-xs mt-1">Drink 8 glasses daily</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
