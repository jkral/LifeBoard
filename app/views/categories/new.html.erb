<div class="modal-content">
  <div class="modal-header">
    <h2 class="text-xl font-semibold text-gray-800">New Category</h2>
    <button type="button" class="close-modal" data-action="click->modal#close">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <%= form_with(model: @category, class: "space-y-4") do |f| %>
    <div class="form-group">
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="form-group">
      <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="form-group">
      <%= f.label :position, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :position, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="modal-footer">
      <%= f.submit "Create Category", class: "btn-primary" %>
      <button type="button" class="btn-secondary" data-action="click->modal#close">Cancel</button>
    </div>
  <% end %>
</div> 