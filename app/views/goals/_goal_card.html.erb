<div class="goal-card bg-white rounded-md border border-gray-200 p-4 shadow-sm hover:shadow-md transition-shadow duration-200"
     data-goal-id="<%= goal.id %>" 
     data-status="<%= goal.status %>"
     draggable="true"
     data-action="dragstart->goals-board#dragStart 
                  dragend->goals-board#dragEnd
                  click->goals-board#showEditForm">
  <div class="goal-card-content">
    <h4 class="goal-title text-base font-medium text-gray-900 mb-1">
      <%= goal.title %>
    </h4>
    <% if goal.description.present? %>
      <p class="goal-description text-sm text-gray-600 mt-1">
        <%= goal.description %>
      </p>
    <% end %>
  </div>
  <div class="goal-actions mt-2 flex justify-end" data-goals-board-target="goalActions">
    <button class="text-gray-400 hover:text-red-500 p-1 rounded-full hover:bg-gray-100 transition-colors" 
            data-action="click->goals-board#deleteGoal"
            data-goal-id="<%= goal.id %>"
            title="Delete goal">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    </button>
  </div>
</div>
